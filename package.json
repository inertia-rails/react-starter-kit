{
  "name": "react_starter_kit",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "eslint '*.{js,mjs,cjs,ts}' app/javascript/ --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint '*.{js,mjs,cjs,ts}' app/javascript/ --fix",
    "format": "prettier --check 'app/javascript' '*.{js,mjs,cjs,ts}'",
    "format:fix": "prettier --write 'app/javascript' '*.{js,mjs,cjs,ts}'"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@inertiajs/react": "^3.5.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@inertiajs/vite": "^3.5.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "lucide-react": "^1.17.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "radix-ui": "^1.5.0",
    "rails-vite-plugin": "^0.2.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
